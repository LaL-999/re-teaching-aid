!server/data/.gitkeep

# local env (real secrets) — only *.example is committed
.env
.env.local
server/.env
client/.env

# logs & os
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/

# Claude Code 临时工作副本（agent worktrees，切勿入库）
.claude/worktrees/
