# ===================== 后端环境变量 =====================
# 复制为 server/.env 后按需修改。仓库已自带一份可直接运行的 server/.env（Mock 模式）。

# --- HTTP ---
PORT=4000
# 允许跨域的前端来源（Vite 默认 5173）
CLIENT_ORIGIN=http://localhost:5173

# --- 认证 ---
# 生产务必替换为高强度随机串
JWT_SECRET=dev-secret-please-change
# 令牌有效期
JWT_EXPIRES_IN=12h

# --- 大模型（OpenAI 兼容接口）---
# 留空 LLM_API_KEY 时，系统自动使用「离线 Mock」，全部 AI 工具仍可演示全部验收场景。
# 国产可选：DeepSeek=https://api.deepseek.com/v1 (模型 deepseek-chat)
#           智谱 = https://open.bigmodel.cn/api/paas/v4 (模型 glm-4-flash)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_MS=30000

# --- PlantUML / Kroki 在线渲染（无需本地 Java）---
# KROKI_SERVER：服务端 POST 渲染 SVG，语法错误返回 HTTP 400，便于回显"编译失败"
# PLANTUML_SERVER：生成"在新标签打开"的 deflate 编码 GET 链接
KROKI_SERVER=https://kroki.io
PLANTUML_SERVER=https://www.plantuml.com/plantuml
